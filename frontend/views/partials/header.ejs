<header class="header">
  <nav class="navbar">
    <div class="container nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">✦</span>
        <span class="logo-text">BlogSpace</span>
      </a>

      <div class="nav-center">
        <form action="/" method="GET" class="nav-search">
          <input type="text" name="search" placeholder="Search posts..." value="<%= typeof search !== 'undefined' ? search : '' %>" />
          <button type="submit" class="search-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          </button>
        </form>
      </div>

      <div class="nav-right">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <span class="theme-icon">🌙</span>
        </button>

        <% if (locals.currentUser) { %>
          <a href="/posts/new" class="btn btn-primary btn-sm">+ Write</a>
          <div class="user-menu">
            <button class="user-avatar-btn" id="userMenuBtn">
              <div class="avatar-circle"><%= currentUser.name.charAt(0).toUpperCase() %></div>
            </button>
            <div class="dropdown-menu" id="userDropdown">
              <div class="dropdown-header">
                <strong><%= currentUser.name %></strong>
                <small><%= currentUser.email %></small>
              </div>
              <a href="/dashboard" class="dropdown-item">📊 Dashboard</a>
              <a href="/settings" class="dropdown-item">⚙️ Settings</a>
              <div class="dropdown-divider"></div>
              <form action="/auth/logout" method="POST">
                <button type="submit" class="dropdown-item dropdown-item-danger">🚪 Logout</button>
              </form>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="btn btn-ghost btn-sm">Login</a>
          <a href="/auth/register" class="btn btn-primary btn-sm">Get Started</a>
        <% } %>

        <button class="mobile-menu-btn" id="mobileMenuBtn">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div class="mobile-nav" id="mobileNav">
      <a href="/" class="mobile-nav-link">Home</a>
      <% if (locals.currentUser) { %>
        <a href="/posts/new" class="mobile-nav-link">Write Post</a>
        <a href="/dashboard" class="mobile-nav-link">Dashboard</a>
        <a href="/settings" class="mobile-nav-link">Settings</a>
        <form action="/auth/logout" method="POST">
          <button type="submit" class="mobile-nav-link mobile-logout">Logout</button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="mobile-nav-link">Login</a>
        <a href="/auth/register" class="mobile-nav-link">Register</a>
      <% } %>
    </div>
  </nav>
</header>
