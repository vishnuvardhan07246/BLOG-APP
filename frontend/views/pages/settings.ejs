<%
const bodyHtml = `
<div class="settings-page">
  <div class="settings-header">
    <h1>Account Settings</h1>
    <p>Manage your profile and account preferences</p>
  </div>

  <div class="settings-layout">
    <nav class="settings-nav">
      <a href="#profile" class="settings-nav-link active">👤 Profile</a>
      <a href="#password" class="settings-nav-link">🔒 Password</a>
      <a href="/dashboard" class="settings-nav-link">📊 Dashboard</a>
    </nav>

    <div class="settings-content">
      <!-- Profile Section -->
      <section class="settings-section" id="profile">
        <div class="settings-section-header">
          <h2>Public Profile</h2>
          <p>This information will be visible to readers of your posts.</p>
        </div>

        <div class="profile-avatar-section">
          <div class="avatar-lg">${currentUser.name.charAt(0).toUpperCase()}</div>
          <div>
            <p><strong>${currentUser.name}</strong></p>
            <p class="text-muted">Member since ${new Date(currentUser.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</p>
          </div>
        </div>

        <form action="/settings?_method=PUT" method="POST" class="settings-form">
          <div class="form-group">
            <label for="name">Display Name</label>
            <input type="text" id="name" name="name" value="${currentUser.name.replace(/"/g, '&quot;')}" required maxlength="50" />
          </div>
          <div class="form-group">
            <label for="bio">Bio <span class="hint">(max 300 characters)</span></label>
            <textarea id="bio" name="bio" rows="3" maxlength="300" placeholder="Tell readers a little about yourself...">${currentUser.bio || ''}</textarea>
          </div>
          <div class="form-group">
            <label for="website">Website</label>
            <input type="url" id="website" name="website" value="${currentUser.website || ''}" placeholder="https://yoursite.com" />
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" value="${currentUser.email}" disabled class="input-disabled" />
            <small class="hint">Email cannot be changed.</small>
          </div>
          <button type="submit" class="btn btn-primary">Save Profile</button>
        </form>
      </section>

      <!-- Password Section -->
      <section class="settings-section" id="password">
        <div class="settings-section-header">
          <h2>Change Password</h2>
          <p>Keep your account secure with a strong password.</p>
        </div>

        <form action="/settings/password?_method=PUT" method="POST" class="settings-form">
          <div class="form-group">
            <label for="currentPassword">Current Password</label>
            <input type="password" id="currentPassword" name="currentPassword" required />
          </div>
          <div class="form-group">
            <label for="newPassword">New Password</label>
            <input type="password" id="newPassword" name="newPassword" required minlength="6" />
          </div>
          <div class="form-group">
            <label for="confirmPassword">Confirm New Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6" />
          </div>
          <button type="submit" class="btn btn-primary">Update Password</button>
        </form>
      </section>
    </div>
  </div>
</div>
`;
%>
<%- include('../layouts/main', { title, body: bodyHtml }) %>
