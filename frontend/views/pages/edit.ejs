<%
const tagsValue = post.tags ? post.tags.join(', ') : '';
const bodyHtml = `
<div class="form-page">
  <div class="form-page-header">
    <h1>Edit Post</h1>
    <a href="/posts/${post._id}" class="btn btn-ghost btn-sm">← Back to Post</a>
  </div>

  <div class="form-card">
    <form action="/posts/${post._id}?_method=PUT" method="POST" class="post-form">
      <div class="form-group">
        <label for="title">Title <span class="required">*</span></label>
        <input type="text" id="title" name="title" value="${post.title.replace(/"/g, '&quot;')}" required maxlength="200" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="category">Category</label>
          <select id="category" name="category">
            ${categories.map(c => `<option value="${c}" ${post.category === c ? 'selected' : ''}>${c}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label for="status">Visibility</label>
          <select id="status" name="status">
            <option value="published" ${post.status === 'published' ? 'selected' : ''}>Published</option>
            <option value="draft" ${post.status === 'draft' ? 'selected' : ''}>Draft (private)</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="tags">Tags <span class="hint">(comma-separated)</span></label>
        <input type="text" id="tags" name="tags" value="${tagsValue}" placeholder="javascript, web-dev, tutorial" />
      </div>

      <div class="form-group">
        <label for="content">Content <span class="required">*</span></label>
        <textarea id="content" name="content" rows="18" required>${post.content}</textarea>
        <div class="content-hint">
          <span id="wordCount">0 words</span>
          <span id="readTimeEstimate">~1 min read</span>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Update Post</button>
        <a href="/posts/${post._id}" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
`;
%>
<%- include('../layouts/main', { title, body: bodyHtml }) %>
