<%- include('../../layouts/main', { title, body: `
<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <a href="/" class="auth-logo">✦ BlogSpace</a>
      <h1>Create your account</h1>
      <p>Join thousands of writers sharing their stories</p>
    </div>

    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="name">Full name</label>
        <input type="text" id="name" name="name" placeholder="Jane Doe" required autocomplete="name" />
      </div>

      <div class="form-group">
        <label for="email">Email address</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" />
      </div>

      <div class="form-group">
        <label for="password">Password <small>(min 6 characters)</small></label>
        <div class="password-wrap">
          <input type="password" id="password" name="password" placeholder="••••••••" required minlength="6" autocomplete="new-password" />
          <button type="button" class="password-toggle" data-target="password">👁</button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-block">Create Account</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/auth/login">Sign in</a></p>
  </div>

  <div class="auth-visual">
    <div class="auth-quote">
      <blockquote>"Start writing, no matter what. The water does not flow until the faucet is turned on."</blockquote>
      <cite>— Louis L'Amour</cite>
    </div>
  </div>
</div>
` }) %>
